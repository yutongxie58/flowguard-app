{
  "manifest_version": 3,
  "name": "FlowGuard Recorder",
  "description": "Record browser workflow traces and turn them into FlowGuard agent plans.",
  "version": "0.1.0",
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": ["http://localhost:5173/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "FlowGuard Recorder",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
