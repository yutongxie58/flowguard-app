PORT=5173

# MongoDB Atlas persistence. Leave unset to use local JSON fallback.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=flowguard

# Optional LLM planner/risk classifier. Leave unset to use rule-based fallback.
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-5-mini

# Optional GitHub integration. Public repo lookup works without this, but a token raises rate limits.
GITHUB_TOKEN=github_pat_your_token

# Demo/testing only. Enables a UI button and endpoint that clears Atlas/local data and restores seed workflows.
ALLOW_DEMO_RESET=false
